@if (
  TempData["SuccessMessage"] != null ||
  TempData["ErrorMessage"] != null ||
 TempData["InfoMessage"] != null ||
TempData["WarningMessage"] != null
  )
{
    if (TempData["SuccessMessage"] != null)
    {
        <script>
            $(document).ready(function () {
                ShowMessage('پیغام موفقیت', '@Html.Raw(@TempData["SuccessMessage"])', 'success');
            });
        </script>
    }

    if (TempData["ErrorMessage"] != null)
    {
        <script>
            $(document).ready(function () {
                ShowMessage('پیغام خطا', '@Html.Raw(@TempData["ErrorMessage"])', 'error');
            });
        </script>
    }

    if (TempData["InfoMessage"] != null)
    {
        <script>
            $(document).ready(function () {
                ShowMessage('پیغام اطلاعیه', '@Html.Raw(@TempData["InfoMessage"])', 'info');
            });
        </script>
    }

    if (TempData["WarningMessage"] != null)
    {
        <script>
            $(document).ready(function () {
                ShowMessage('پیغام اخطار', '@Html.Raw(@TempData["WarningMessage"])', 'warning');
            });
        </script>
    }
}

